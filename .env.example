######
# DB #
######

DB_HOST=db
DB_PORT=3306
DB_USERNAME=std_notes_user
DB_PASSWORD=replace-with-a-secure-random-password
DB_DATABASE=standard_notes_db
DB_TYPE=mysql

#########
# CACHE #
#########

REDIS_PORT=6379
REDIS_HOST=cache
CACHE_TYPE=redis

########
# KEYS #
########

# Generate each with: openssl rand -hex 32
AUTH_JWT_SECRET=replace-with-64-hex-chars
AUTH_SERVER_ENCRYPTION_SERVER_KEY=replace-with-64-hex-chars
VALET_TOKEN_SECRET=replace-with-64-hex-chars

########
# AUTH #
########

# Keep false until your first account is registered, then set true and restart.
AUTH_SERVER_DISABLE_USER_REGISTRATION=false

#########
# FILES #
#########

# Required for Standard Notes file uploads. The installer writes this as:
# PUBLIC_FILES_SERVER_URL=https://files.example.com
PUBLIC_FILES_SERVER_URL=https://files.example.com
