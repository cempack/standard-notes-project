#!/usr/bin/env bash
set -Eeuo pipefail
IFS=$'\n\t'

PROJECT_DIR="${SN_PROJECT_DIR:-/opt/standardnotes}"
ENV_FILE="$PROJECT_DIR/.env"
COMPOSE_FILE="$PROJECT_DIR/docker-compose.yml"

if [[ -t 1 ]]; then
  RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; BOLD='\033[1m'; RESET='\033[0m'
else
  RED=''; GREEN=''; YELLOW=''; BLUE=''; BOLD=''; RESET=''
fi

log() { printf '[%s] %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*"; }
ok() { printf '%b[OK]%b %s\n' "$GREEN" "$RESET" "$*"; }
warn() { printf '%b[WARN]%b %s\n' "$YELLOW" "$RESET" "$*"; }
die() { printf '%b[ERROR]%b %s\n' "$RED" "$RESET" "$*" >&2; exit 1; }

usage() {
  cat <<USAGE
${BOLD}snctl${RESET} - Standard Notes self-host control CLI

Usage:
  snctl COMMAND [ARGS]

Commands:
  status                         Show Docker Compose service status
  health                         Run the full health checker
  test                           Run guided verification commands
  logs [service]                 Follow Docker logs, default service: server
  backup                         Run a manual backup
  restore BACKUP.tar.gz          Restore from a backup archive
  update                         Backup, pull images, restart, and health check

Account / registration:
  first-account EMAIL            Guided flow: enable registration, wait for EMAIL,
                                 grant server-side PRO_PLAN, optionally lock registration
  grant-pro EMAIL [--wait]       Grant server-side PRO_USER/PRO_PLAN to EMAIL
  lock-registration              Set AUTH_SERVER_DISABLE_USER_REGISTRATION=true and restart
  unlock-registration            Set AUTH_SERVER_DISABLE_USER_REGISTRATION=false and restart
  registration-status            Print current registration setting

Other:
  dashboard                      Print dashboard URL from .install-config
  help                           Show this help

Environment:
  SN_PROJECT_DIR=/opt/standardnotes   Override install directory

Examples:
  snctl first-account you@example.com
  snctl grant-pro you@example.com --wait
  snctl lock-registration
  snctl health
USAGE
}

require_project() {
  [[ -d "$PROJECT_DIR" ]] || die "Project directory not found: $PROJECT_DIR"
  [[ -f "$COMPOSE_FILE" ]] || die "Missing $COMPOSE_FILE"
}

require_env() {
  require_project
  [[ -f "$ENV_FILE" ]] || die "Missing $ENV_FILE. Run install.sh first."
}

compose() {
  require_env
  docker compose -f "$COMPOSE_FILE" --env-file "$ENV_FILE" "$@"
}

normalize_bool() {
  case "${1:-}" in
    true|TRUE|1|yes|YES|y|Y) printf 'true' ;;
    *) printf 'false' ;;
  esac
}

get_env_value() {
  local key="$1" line value
  [[ -f "$ENV_FILE" ]] || return 1
  line="$(grep -E "^${key}=" "$ENV_FILE" | tail -n1 || true)"
  [[ -n "$line" ]] || return 1
  value="${line#*=}"
  value="${value%$'\r'}"
  value="${value%\"}"; value="${value#\"}"
  value="${value%\'}"; value="${value#\'}"
  printf '%s' "$value"
}

set_env_value() {
  local key="$1" value="$2" tmp
  require_env
  tmp="$(mktemp)"
  if grep -qE "^${key}=" "$ENV_FILE"; then
    awk -v k="$key" -v v="$value" 'BEGIN{done=0} $0 ~ "^" k "=" {print k "=" v; done=1; next} {print} END{if(done==0) print k "=" v}' "$ENV_FILE" > "$tmp"
  else
    cat "$ENV_FILE" > "$tmp"
    printf '\n%s=%s\n' "$key" "$value" >> "$tmp"
  fi
  cat "$tmp" > "$ENV_FILE"
  rm -f "$tmp"
  chmod 600 "$ENV_FILE" 2>/dev/null || true
}

restart_stack() {
  compose up -d
}

set_registration() {
  local enabled="$1" disable_value
  if [[ "$enabled" == "true" ]]; then
    disable_value="false"
  else
    disable_value="true"
  fi
  set_env_value AUTH_SERVER_DISABLE_USER_REGISTRATION "$disable_value"
  log "Set AUTH_SERVER_DISABLE_USER_REGISTRATION=$disable_value"
  restart_stack
}

registration_status() {
  require_env
  local disabled
  disabled="$(get_env_value AUTH_SERVER_DISABLE_USER_REGISTRATION || printf 'false')"
  disabled="$(normalize_bool "$disabled")"
  if [[ "$disabled" == "true" ]]; then
    printf 'Registration is locked: AUTH_SERVER_DISABLE_USER_REGISTRATION=true\n'
  else
    printf 'Registration is open: AUTH_SERVER_DISABLE_USER_REGISTRATION=false\n'
  fi
}

read_install_config_value() {
  local key="$1" file="$PROJECT_DIR/.install-config" line value
  [[ -f "$file" ]] || return 1
  line="$(grep -E "^${key}=" "$file" | tail -n1 || true)"
  [[ -n "$line" ]] || return 1
  value="${line#*=}"
  value="${value%$'\r'}"
  value="${value%\"}"; value="${value#\"}"
  value="${value%\'}"; value="${value#\'}"
  printf '%s' "$value"
}

cmd_first_account() {
  local email="${1:-}"
  [[ -n "$email" ]] || die "Usage: snctl first-account EMAIL"
  require_env

  cat <<INTRO
${BOLD}Guided first-account setup${RESET}

This will:
  1. Ensure registration is open.
  2. Wait for account ${email} to exist in the database.
  3. Grant the account server-side PRO_USER/PRO_PLAN.
  4. Ask whether to lock registration afterward.

In the Standard Notes desktop/mobile app, set Sync Server to your notes URL,
then register ${email}.
INTRO

  set_registration true

  local notes_domain notes_url
  notes_domain="$(read_install_config_value NOTES_DOMAIN || true)"
  if [[ -n "$notes_domain" ]]; then
    notes_url="https://${notes_domain}"
    printf '\nSync Server URL: %s\n' "$notes_url"
  fi

  printf '\nWaiting up to 30 minutes for account registration...\n'
  "$PROJECT_DIR/scripts/grant-pro-subscription.sh" --wait --timeout 1800 "$email"

  ok "Granted server-side PRO_PLAN to $email"

  local answer
  read -r -p "Lock new user registration now? [Y/n]: " answer
  answer="${answer:-Y}"
  case "$answer" in
    y|Y|yes|YES)
      set_registration false
      ok "Registration locked"
      ;;
    *)
      warn "Registration left open. Lock later with: snctl lock-registration"
      ;;
  esac
}

cmd_dashboard() {
  local notes_domain
  notes_domain="$(read_install_config_value NOTES_DOMAIN || true)"
  if [[ -n "$notes_domain" ]]; then
    printf 'https://%s/dashboard/\n' "$notes_domain"
  else
    printf 'Dashboard is normally at https://YOUR_NOTES_DOMAIN/dashboard/\n'
  fi
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    help|-h|--help)
      usage
      ;;
    status|ps)
      compose ps
      ;;
    health)
      require_project
      "$PROJECT_DIR/scripts/healthcheck.sh"
      ;;
    test)
      require_project
      "$PROJECT_DIR/scripts/test.sh"
      ;;
    logs)
      require_env
      service="${1:-server}"
      compose logs -f "$service"
      ;;
    backup)
      require_project
      "$PROJECT_DIR/scripts/backup.sh"
      ;;
    restore)
      require_project
      [[ -n "${1:-}" ]] || die "Usage: snctl restore BACKUP.tar.gz"
      "$PROJECT_DIR/scripts/restore.sh" "$1"
      ;;
    update)
      require_project
      "$PROJECT_DIR/scripts/update.sh"
      ;;
    grant-pro)
      require_project
      "$PROJECT_DIR/scripts/grant-pro-subscription.sh" "$@"
      ;;
    first-account)
      cmd_first_account "${1:-}"
      ;;
    lock-registration)
      set_registration false
      ;;
    unlock-registration)
      set_registration true
      ;;
    registration-status)
      registration_status
      ;;
    dashboard)
      cmd_dashboard
      ;;
    *)
      die "Unknown command: $cmd. Run: snctl help"
      ;;
  esac
}

main "$@"
