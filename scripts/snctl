#!/usr/bin/env bash
set -Eeuo pipefail
IFS=$'\n\t'

PROJECT_DIR="${SN_PROJECT_DIR:-/opt/standardnotes}"
ENV_FILE="$PROJECT_DIR/.env"
COMPOSE_FILE="$PROJECT_DIR/docker-compose.yml"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=ui.sh
source "$SCRIPT_DIR/ui.sh" 2>/dev/null || true

if [[ -z "${UI_VERSION:-}" ]]; then
  if [[ -t 1 ]]; then
    RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; CYAN='\033[0;36m'; MAGENTA='\033[0;35m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'
  else
    RED=''; GREEN=''; YELLOW=''; BLUE=''; CYAN=''; MAGENTA=''; BOLD=''; DIM=''; RESET=''
  fi
fi

log()  { printf '%b  %b[%s]%b %s\n' "$DIM" "$RESET$DIM" "$(date -u +%H:%M:%S)" "$RESET" "$*"; }
ok()   { printf '%b  ✓%b %s\n' "$GREEN" "$RESET" "$*"; }
warn() { printf '%b  ⚠%b %s\n' "$YELLOW" "$RESET" "$*"; }
die()  { printf '%b  ✗%b %s\n' "$RED" "$RESET" "$*" >&2; exit 1; }

usage() {
  printf '\n'
  printf '  %b┌─────────────────────────────────────────┐%b\n' "$DIM" "$RESET"
  printf '  %b│%b  %bsnctl%b · Standard Notes Control CLI      %b│%b\n' "$DIM" "$RESET" "$BOLD$CYAN" "$RESET" "$DIM" "$RESET"
  printf '  %b└─────────────────────────────────────────┘%b\n' "$DIM" "$RESET"
  printf '\n'
  printf '  %bUSAGE%b\n' "$BOLD" "$RESET"
  printf '    %bsnctl%b %b<command>%b %b[args]%b\n' "$CYAN" "$RESET" "$MAGENTA" "$RESET" "$DIM" "$RESET"
  printf '\n'
  printf '  %b─── Operations ──────────────────────────────%b\n' "$DIM" "$RESET"
  printf '    %b%bstatus%b           %bShow Docker Compose service status%b\n' "$CYAN" "$BOLD" "$RESET" "$DIM" "$RESET"
  printf '    %b%bhealth%b           %bRun the full health checker%b\n' "$CYAN" "$BOLD" "$RESET" "$DIM" "$RESET"
  printf '    %b%btest%b             %bRun guided verification commands%b\n' "$CYAN" "$BOLD" "$RESET" "$DIM" "$RESET"
  printf '    %b%blogs%b %b[service]%b   %bFollow Docker logs (default: server)%b\n' "$CYAN" "$BOLD" "$RESET" "$DIM" "$RESET" "$DIM" "$RESET"
  printf '    %b%bbackup%b           %bRun a manual backup%b\n' "$CYAN" "$BOLD" "$RESET" "$DIM" "$RESET"
  printf '    %b%brestore%b %bARCHIVE%b  %bRestore from a backup archive%b\n' "$CYAN" "$BOLD" "$RESET" "$DIM" "$RESET" "$DIM" "$RESET"
  printf '    %b%bupdate%b           %bBackup, pull, restart, health check%b\n' "$CYAN" "$BOLD" "$RESET" "$DIM" "$RESET"
  printf '\n'
  printf '  %b─── Account & Registration ─────────────────%b\n' "$DIM" "$RESET"
  printf '    %b%bfirst-account%b %bEMAIL%b\n' "$CYAN" "$BOLD" "$RESET" "$DIM" "$RESET"
  printf '                     %bGuided: register → grant PRO → lock%b\n' "$DIM" "$RESET"
  printf '    %b%bgrant-pro%b %bEMAIL [--wait]%b\n' "$CYAN" "$BOLD" "$RESET" "$DIM" "$RESET"
  printf '                     %bGrant server-side PRO_USER/PRO_PLAN%b\n' "$DIM" "$RESET"
  printf '    %b%block-registration%b    %bDisable new user sign-ups%b\n' "$CYAN" "$BOLD" "$RESET" "$DIM" "$RESET"
  printf '    %b%bunlock-registration%b  %bRe-enable sign-ups%b\n' "$CYAN" "$BOLD" "$RESET" "$DIM" "$RESET"
  printf '    %b%bregistration-status%b %bPrint current setting%b\n' "$CYAN" "$BOLD" "$RESET" "$DIM" "$RESET"
  printf '\n'
  printf '  %b─── Other ──────────────────────────────────%b\n' "$DIM" "$RESET"
  printf '    %b%bdashboard%b        %bPrint dashboard URL%b\n' "$CYAN" "$BOLD" "$RESET" "$DIM" "$RESET"
  printf '    %b%bhelp%b             %bShow this help%b\n' "$CYAN" "$BOLD" "$RESET" "$DIM" "$RESET"
  printf '\n'
  printf '  %bENVIRONMENT%b\n' "$BOLD" "$RESET"
  printf '    %bSN_PROJECT_DIR%b=%b/opt/standardnotes%b  %bOverride install dir%b\n' "$CYAN" "$RESET" "$MAGENTA" "$RESET" "$DIM" "$RESET"
  printf '\n'
  printf '  %bEXAMPLES%b\n' "$BOLD" "$RESET"
  printf '    %b$%b %bsnctl first-account you@example.com%b\n' "$DIM" "$RESET" "$CYAN" "$RESET"
  printf '    %b$%b %bsnctl grant-pro you@example.com --wait%b\n' "$DIM" "$RESET" "$CYAN" "$RESET"
  printf '    %b$%b %bsnctl lock-registration%b\n' "$DIM" "$RESET" "$CYAN" "$RESET"
  printf '    %b$%b %bsnctl health%b\n' "$DIM" "$RESET" "$CYAN" "$RESET"
  printf '\n'
  printf '  %b%bsnctl v1.0%b  %b·  Standard Notes Self-Hosted%b\n' "$DIM" "$BOLD" "$RESET" "$DIM" "$RESET"
  printf '\n'
}

require_project() {
  [[ -d "$PROJECT_DIR" ]] || die "Project directory not found: $PROJECT_DIR"
  [[ -f "$COMPOSE_FILE" ]] || die "Missing $COMPOSE_FILE"
}

require_env() {
  require_project
  [[ -f "$ENV_FILE" ]] || die "Missing $ENV_FILE. Run install.sh first."
}

compose() {
  require_env
  docker compose -f "$COMPOSE_FILE" --env-file "$ENV_FILE" "$@"
}

normalize_bool() {
  case "${1:-}" in
    true|TRUE|1|yes|YES|y|Y) printf 'true' ;;
    *) printf 'false' ;;
  esac
}

get_env_value() {
  local key="$1" line value
  [[ -f "$ENV_FILE" ]] || return 1
  line="$(grep -E "^${key}=" "$ENV_FILE" | tail -n1 || true)"
  [[ -n "$line" ]] || return 1
  value="${line#*=}"
  value="${value%$'\r'}"
  value="${value%\"}"; value="${value#\"}"
  value="${value%\'}"; value="${value#\'}"
  printf '%s' "$value"
}

set_env_value() {
  local key="$1" value="$2" tmp
  require_env
  tmp="$(mktemp)"
  if grep -qE "^${key}=" "$ENV_FILE"; then
    awk -v k="$key" -v v="$value" 'BEGIN{done=0} $0 ~ "^" k "=" {print k "=" v; done=1; next} {print} END{if(done==0) print k "=" v}' "$ENV_FILE" > "$tmp"
  else
    cat "$ENV_FILE" > "$tmp"
    printf '\n%s=%s\n' "$key" "$value" >> "$tmp"
  fi
  cat "$tmp" > "$ENV_FILE"
  rm -f "$tmp"
  chmod 600 "$ENV_FILE" 2>/dev/null || true
}

restart_stack() {
  compose up -d
}

set_registration() {
  local enabled="$1" disable_value
  if [[ "$enabled" == "true" ]]; then
    disable_value="false"
  else
    disable_value="true"
  fi
  set_env_value AUTH_SERVER_DISABLE_USER_REGISTRATION "$disable_value"
  log "Set AUTH_SERVER_DISABLE_USER_REGISTRATION=$disable_value"
  restart_stack
}

registration_status() {
  require_env
  local disabled
  disabled="$(get_env_value AUTH_SERVER_DISABLE_USER_REGISTRATION || printf 'false')"
  disabled="$(normalize_bool "$disabled")"
  if [[ "$disabled" == "true" ]]; then
    printf 'Registration is locked: AUTH_SERVER_DISABLE_USER_REGISTRATION=true\n'
  else
    printf 'Registration is open: AUTH_SERVER_DISABLE_USER_REGISTRATION=false\n'
  fi
}

read_install_config_value() {
  local key="$1" file="$PROJECT_DIR/.install-config" line value
  [[ -f "$file" ]] || return 1
  line="$(grep -E "^${key}=" "$file" | tail -n1 || true)"
  [[ -n "$line" ]] || return 1
  value="${line#*=}"
  value="${value%$'\r'}"
  value="${value%\"}"; value="${value#\"}"
  value="${value%\'}"; value="${value#\'}"
  printf '%s' "$value"
}

cmd_first_account() {
  local email="${1:-}"
  [[ -n "$email" ]] || die "Usage: snctl first-account EMAIL"
  require_env

  printf '\n'
  printf '  %b┌─────────────────────────────────────────┐%b\n' "$DIM" "$RESET"
  printf '  %b│%b  %b%bGuided First-Account Setup%b              %b│%b\n' "$DIM" "$RESET" "$BOLD" "$CYAN" "$RESET" "$DIM" "$RESET"
  printf '  %b└─────────────────────────────────────────┘%b\n' "$DIM" "$RESET"
  printf '\n'
  printf '  %bThis wizard will walk you through creating your\n  first account and granting it PRO status.%b\n' "$DIM" "$RESET"
  printf '\n'
  printf '  %b①%b  Ensure registration is open\n' "$CYAN" "$RESET"
  printf '  %b②%b  Wait for %b%b%s%b to register\n' "$CYAN" "$RESET" "$BOLD" "$MAGENTA" "$email" "$RESET"
  printf '  %b③%b  Grant server-side %bPRO_USER/PRO_PLAN%b\n' "$CYAN" "$RESET" "$BOLD" "$RESET"
  printf '  %b④%b  Optionally lock registration\n' "$CYAN" "$RESET"
  printf '\n'
  printf '  %b─────────────────────────────────────────────%b\n' "$DIM" "$RESET"
  printf '  %bOpen the Standard Notes app and set Sync Server%b\n' "$DIM" "$RESET"
  printf '  %bto your notes URL, then register %b%s%b.%b\n' "$DIM" "$BOLD" "$email" "$RESET$DIM" "$RESET"
  printf '\n'

  log "Step 1/4 — Opening registration"
  set_registration true

  local notes_domain notes_url
  notes_domain="$(read_install_config_value NOTES_DOMAIN || true)"
  if [[ -n "$notes_domain" ]]; then
    notes_url="https://${notes_domain}"
    printf '  %b⮑  Sync Server URL:%b %b%s%b\n\n' "$DIM" "$RESET" "$BOLD$CYAN" "$notes_url" "$RESET"
  fi

  log "Step 2/4 — Waiting up to 30 min for registration"
  printf '\n'
  "$PROJECT_DIR/scripts/grant-pro-subscription.sh" --wait --timeout 1800 "$email"

  ok "Granted server-side PRO_PLAN to $email"
  printf '\n'

  local answer
  printf '  %b④%b  ' "$CYAN" "$RESET"
  read -r -p "Lock new user registration now? [Y/n]: " answer
  answer="${answer:-Y}"
  case "$answer" in
    y|Y|yes|YES)
      set_registration false
      ok "Registration locked"
      ;;
    *)
      warn "Registration left open. Lock later with: snctl lock-registration"
      ;;
  esac
  printf '\n'
}

cmd_dashboard() {
  local notes_domain
  notes_domain="$(read_install_config_value NOTES_DOMAIN || true)"
  if [[ -n "$notes_domain" ]]; then
    printf 'https://%s/dashboard/\n' "$notes_domain"
  else
    printf 'Dashboard is normally at https://YOUR_NOTES_DOMAIN/dashboard/\n'
  fi
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    help|-h|--help)
      show_banner 2>/dev/null || true
      usage
      ;;
    status|ps)
      compose ps
      ;;
    health)
      require_project
      "$PROJECT_DIR/scripts/healthcheck.sh"
      ;;
    test)
      require_project
      "$PROJECT_DIR/scripts/test.sh"
      ;;
    logs)
      require_env
      service="${1:-server}"
      compose logs -f "$service"
      ;;
    backup)
      require_project
      "$PROJECT_DIR/scripts/backup.sh"
      ;;
    restore)
      require_project
      [[ -n "${1:-}" ]] || die "Usage: snctl restore BACKUP.tar.gz"
      "$PROJECT_DIR/scripts/restore.sh" "$1"
      ;;
    update)
      require_project
      "$PROJECT_DIR/scripts/update.sh"
      ;;
    grant-pro)
      require_project
      "$PROJECT_DIR/scripts/grant-pro-subscription.sh" "$@"
      ;;
    first-account)
      show_banner 2>/dev/null || true
      cmd_first_account "${1:-}"
      ;;
    lock-registration)
      set_registration false
      ;;
    unlock-registration)
      set_registration true
      ;;
    registration-status)
      registration_status
      ;;
    dashboard)
      cmd_dashboard
      ;;
    *)
      die "Unknown command: $cmd. Run: snctl help"
      ;;
  esac
}

main "$@"
